#!/bin/sh
# Synod Gemini wrapper: routes to agy (Antigravity CLI, Gemini 3.5 Flash).
#
# Synod still passes its historical --model/--thinking/--timeout flags.  agy
# does not expose a non-interactive --model flag, so this wrapper consumes those
# compatibility flags, keeps Antigravity configured on the Gemini 3.5 Flash
# family, then calls `agy --print` through `script` to provide the PTY agy
# expects.
#
# Prompt/prefix caching (SYNOD_PROMPT_CACHE): agy delegates all session
# management and context reuse entirely to Antigravity CLI and the upstream
# Gemini API.  There is no request-construction layer in this wrapper where
# cache_control markers could be injected, so prompt caching for the agy path
# is provider-managed and out of scope here.  See tools/base_provider.py
# (build_cached_messages) and tools/cliproxy-cli.py for the implementation
# that handles the OpenAI-compatible providers.

while [ $# -gt 0 ]; do
    case "$1" in
        --model|-m|--thinking|-t|--timeout|--temperature|--retries)
            shift 2
            ;;
        --no-stream|--no-adaptive|--verbose|-v)
            shift
            ;;
        --)
            shift
            break
            ;;
        -*)
            shift
            ;;
        *)
            break
            ;;
    esac
done

stdin_prompt=""
if [ ! -t 0 ]; then
    stdin_prompt=$(cat)
fi

if [ -n "$stdin_prompt" ]; then
    prompt=$stdin_prompt
elif [ $# -gt 0 ]; then
    prompt=$*
else
    prompt=""
fi

[ -z "$prompt" ] && { echo "Error: No prompt provided" >&2; exit 1; }

if ! command -v agy >/dev/null 2>&1; then
    echo "Error: agy command not found. Install Google Antigravity CLI first." >&2
    exit 1
fi

# If the user already selected any Gemini 3.5 Flash strength in Antigravity,
# keep that exact strength. Otherwise pin Synod back to Gemini 3.5 Flash.
# Set SYNOD_AGY_MODEL_LABEL to force an exact label, e.g.
#   SYNOD_AGY_MODEL_LABEL='Gemini 3.5 Flash (Medium)'
python3 - <<'PY' 2>/dev/null || true
import json
import os
from pathlib import Path

settings_path = Path.home() / ".gemini" / "antigravity-cli" / "settings.json"
forced_label = os.environ.get("SYNOD_AGY_MODEL_LABEL", "").strip()
default_label = "Gemini 3.5 Flash (Medium)"

if not settings_path.exists():
    settings_path.parent.mkdir(parents=True, exist_ok=True)
    settings = {}
else:
    try:
        settings = json.loads(settings_path.read_text())
    except Exception:
        settings = {}

current = str(settings.get("model", "")).strip()
target = forced_label or default_label

if forced_label or not current.startswith("Gemini 3.5 Flash"):
    settings["model"] = target
    settings_path.write_text(json.dumps(settings, ensure_ascii=False, indent=2) + "\n")
PY

# macOS `script -q /dev/null cmd ...` provides the PTY required by agy; strip
# terminal CR and the EOF marker that script can append.
#
# Failure propagation: the previous pipeline masked agy failures because the
# pipeline exit status was the python filter's (always 0) and agy stderr was
# discarded. Capture agy's output and exit code, surface its stderr, and treat
# BOTH a non-zero exit AND empty output as failure so Synod never mistakes a
# failed Gemini call for a valid response.
_agy_err=$(mktemp 2>/dev/null || echo "/tmp/agy_err.$$")
_agy_raw=$(script -q /dev/null agy --print "$prompt" 2>"$_agy_err")
_agy_rc=$?
_agy_out=$(printf '%s' "$_agy_raw" | python3 -c 'import sys; data=sys.stdin.read().replace("^D\b\b", "").replace("\r", "").replace("\x04", ""); sys.stdout.write(data)')

if [ "$_agy_rc" -ne 0 ] || [ -z "$_agy_out" ]; then
    [ -s "$_agy_err" ] && cat "$_agy_err" >&2
    rm -f "$_agy_err"
    echo "Error: agy --print failed (exit=$_agy_rc, output_empty=$([ -z "$_agy_out" ] && echo yes || echo no))" >&2
    [ "$_agy_rc" -ne 0 ] && exit "$_agy_rc"
    exit 1
fi

rm -f "$_agy_err"
printf '%s' "$_agy_out"
